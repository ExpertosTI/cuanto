# Auth API
AUTH_SECRET=change-me-long-random
# Admin (OTP llega aquí). Salida SMTP = info@renace.tech
MASTER_EMAILS=expertostird@gmail.com
# Opcional: números master (solo dígitos, separados por coma). Vacío = bootstrap del primero.
MASTER_PHONES=
# 1 = devolver el OTP real generado en la respuesta (solo depuración)
AUTH_DEV_SHOW_CODE=0

# SMTP (mismo patrón PrestaPro / Hostinger — sale desde info@)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=info@renace.tech
SMTP_PASS=
SMTP_FROM='Cuanto <info@renace.tech>'

# Evolution API — preferí URL interna en el VPS (como PrestaPro):
# EVOLUTION_API_URL=http://evolution_api:8080
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
# Vacío = descubrir con /instance/fetchInstances (open primero)
EVOLUTION_INSTANCE=
WHATSAPP_BUSINESS=

# Agente (opcional)
GEMINI_API_KEY=
